# Telegram Group Messaging Automation
# Environment Configuration Template

# ============================================
# REQUIRED: Telegram API Credentials
# ============================================
# Get these from https://my.telegram.org/apps
API_ID=your_api_id_here
API_HASH=your_api_hash_here

# Session string for authentication
# You can generate this using Telethon or obtain it from a logged-in session
SESSION_STRING=

# ============================================
# Flask Configuration
# ============================================
HOST=0.0.0.0
PORT=5000
DEBUG=false

# ============================================
# Message Automation Settings
# ============================================
DEFAULT_DELAY_MIN=10
DEFAULT_DELAY_MAX=30
MAX_MESSAGES_PER_RUN=50

# ============================================
# Directory Configuration
# ============================================
DATA_DIR=data
LOGS_DIR=logs

# ============================================
# Ad Delivery Settings
# ============================================
# Directory containing ad content and manifest.json
CONTENT_DIR=content

# Daily delivery time in HH:MM format (24-hour)
SCHEDULE_TIME=09:00

# Timezone for the schedule (IANA timezone name)
SCHEDULE_TIMEZONE=UTC

# Path to the delivery ledger (idempotency tracking)
DELIVERY_LEDGER_PATH=data/delivery_ledger.json

# Maximum retry attempts for failed deliveries
DELIVERY_MAX_RETRIES=3

# Delay in seconds between deliveries to different destinations
DELIVERY_INTER_DELAY=5.0
